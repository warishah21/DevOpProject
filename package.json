    "dotenv": "^17.4.2",
    "express": "^4.18.2",
    "jsonwebtoken": "^9.0.2",
    "lucide-react": "^0.344.0",
    "mongodb": "^6.3.0",
    "mongoose": "^8.0.1",
    "react": "^18.3.1",
    "react-bootstrap": "^2.9.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.19.0",
    "socket.io": "^4.7.2",
    "socket.io-client": "^4.7.2"
  },
  "devDependencies": {
    "@eslint/js": "^9.9.1",
