# Copy to .env and adjust. Values here match local dev defaults.

MONGODB_URI=mongodb://localhost:27017/doctor-patient-portal
JWT_SECRET=change_this_to_a_long_random_string
PORT=5000

# HTTPS deployments: set COOKIE_SECURE=true so auth cookies are only sent over TLS
COOKIE_SECURE=false

# Browser origin for CORS + Socket.IO (must match the URL you use in the browser)
CLIENT_ORIGIN=http://localhost:5173

# Frontend (Vite reads these automatically from .env)
VITE_API_URL=http://localhost:5000/api
VITE_SOCKET_URL=http://localhost:5000

# --- Docker (docker-compose.yml sets these; override when needed) ---
# CLIENT_ORIGIN=http://localhost:8080
# JWT_SECRET=...
